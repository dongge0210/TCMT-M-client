<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:TCMT.Avalonia.Core.Converters">

    <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    <converters:BoolInvertConverter x:Key="BoolInvertConverter"/>
    <converters:PercentToAngleConverter x:Key="PercentToAngleConverter"/>
    <converters:PercentToWarningColorConverter x:Key="PercentToWarningColorConverter"/>
    <converters:NullToDefaultConverter x:Key="NullToDefaultConverter"/>
    <converters:BytesToHumanReadableConverter x:Key="BytesToHumanReadableConverter"/>
    <converters:FrequencyConverter x:Key="FrequencyConverter"/>
    <converters:PowerConverter x:Key="PowerConverter"/>
    <converters:GreaterThanZeroToBoolConverter x:Key="GreaterThanZeroToBoolConverter"/>
    <converters:PercentToWidthConverter x:Key="PercentToWidthConverter"/>
    <converters:NavSelectedToBgConverter x:Key="NavSelectedToBgConverter"/>
    <converters:NavSelectedToFgConverter x:Key="NavSelectedToFgConverter"/>
    <converters:NavSelectedToFontWeightConverter x:Key="NavSelectedToFontWeightConverter"/>
    <converters:IconToGeometryConverter x:Key="IconToGeometryConverter"/>

</ResourceDictionary>