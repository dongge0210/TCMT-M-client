<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:TCMT.Avalonia"
             xmlns:themes="clr-namespace:TCMT.Avalonia.Themes"
             mc:Ignorable="d"
             x:Class="TCMT.Avalonia.App"
             RequestedThemeVariant="Dark">

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://TCMT.Avalonia/Themes/DarkTheme.axaml" />
        <ResourceInclude Source="avares://TCMT.Avalonia/Core/Converters/Converters.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>