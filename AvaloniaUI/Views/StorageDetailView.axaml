<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaUI.ViewModels"
             xmlns:converters="clr-namespace:AvaloniaUI.Converters"
             x:Class="AvaloniaUI.Views.StorageDetailView"
             x:DataType="vm:StorageDetailViewModel">
    
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="25,25,25,0">
            <TextBlock Text="Storage Deep Dive" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Detailed SMART metrics and physical disk health" FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Padding="25">
            <StackPanel Spacing="20">
                <Border Background="#FF1E1E1E" CornerRadius="16" Padding="25" BorderBrush="#FF2A2A2A" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="PHYSICAL DISKS" Foreground="#FF666666" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                            <Button Grid.Column="1" Content="SMART Details" Command="{Binding ToggleSmartDetailCommand}"
                                    IsEnabled="{Binding SelectedPhysicalDisk.Disk.SmartSupported}"
                                    Padding="10,4" FontSize="11"/>
                        </Grid>

                        <ComboBox ItemsSource="{Binding PhysicalDisks}" SelectedItem="{Binding SelectedPhysicalDisk}" 
                                  HorizontalAlignment="Stretch" Margin="0,10,0,10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Disk Basic Info -->
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Spacing="5">
                                <TextBlock Text="MODEL" FontSize="9" Foreground="Gray"/>
                                <TextBlock Text="{Binding SelectedPhysicalDisk.Disk.Model}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedPhysicalDisk.Disk.SerialNumber, StringFormat='S/N: {0}'}" Foreground="#FF666666" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock Text="HEALTH" FontSize="9" Foreground="Gray"/>
                                <TextBlock Text="{Binding SelectedPhysicalDisk.Disk.HealthPercentage, StringFormat='{}{0}%'}" 
                                           Foreground="#FF4CAF50" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedPhysicalDisk.Disk.Temperature, StringFormat='{}{0}°C'}" Foreground="#FFB3B3B3" FontSize="12"/>
                            </StackPanel>
                        </Grid>

                        <!-- SMART Attributes Table -->
                        <Border IsVisible="{Binding SmartDetailVisible}" Background="#FF121212" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="40,*,50,50,120">
                                    <TextBlock Grid.Column="0" Text="ID" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="NAME" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="CUR" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="WORST" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="RAW VALUE" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                                </Grid>
                                <Separator Background="#FF333333" Height="1"/>
                                <ItemsControl ItemsSource="{Binding SelectedPhysicalDisk.Disk.Attributes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="40,*,50,50,120" Margin="0,4">
                                                <TextBlock Grid.Column="0" Text="{Binding Id, StringFormat={}{0:X2}}" Foreground="#FFB3B3B3" FontSize="11"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" FontSize="11"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Current}" Foreground="#FFB3B3B3" FontSize="11"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Worst}" Foreground="#FFB3B3B3" FontSize="11"/>
                                                <TextBlock Grid.Column="4" Text="{Binding RawValue, StringFormat={}{0:X12}}" Foreground="#FF4CAF50" FontFamily="Consolas,Monospace" FontSize="11"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
