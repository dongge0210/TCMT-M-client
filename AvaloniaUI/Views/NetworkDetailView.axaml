<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaUI.ViewModels"
             x:Class="AvaloniaUI.Views.NetworkDetailView"
             x:DataType="vm:NetworkDetailViewModel">

  <Design.DataContext>
    <vm:NetworkDetailViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">
    <!-- Header -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="30,28,30,0">
      <StackPanel>
        <TextBlock Text="Network Adapters" FontSize="26" FontWeight="Bold" Foreground="White"/>
        <TextBlock Text="Real-time network activity and adapter information" FontSize="13" Foreground="#FF888888" Margin="0,4,0,0"/>
      </StackPanel>
    </Grid>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" Padding="30,20">
      <ItemsControl ItemsSource="{Binding NetworkAdapters}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="16"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="#FF1E1E1E" CornerRadius="16" Padding="24" BorderBrush="#FF2A2A2A" BorderThickness="1">
              <Grid ColumnDefinitions="*,Auto,Auto">
                <!-- Left: Adapter Info -->
                <StackPanel Grid.Column="0" Spacing="8">
                  <Grid ColumnDefinitions="Auto,*">
                    <Border Width="32" Height="32" CornerRadius="8" Background="#FF2A2A2A" Margin="0,0,12,0" VerticalAlignment="Top">
                      <TextBlock Text="🌐" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                      <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                      <TextBlock Text="{Binding AdapterType}" FontSize="11" Foreground="#FF888888"/>
                      <TextBlock Text="{Binding Mac, StringFormat='MAC: {0}'}" FontSize="10" Foreground="#FF666666" FontFamily="Consolas,Monospace"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>

                <!-- Center: Speed Stats -->
                <StackPanel Grid.Column="1" Spacing="6" MinWidth="160" VerticalAlignment="Center" Margin="20,0">
                  <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="↓ Download" FontSize="9" Foreground="Gray"/>
                      <TextBlock Text="{Binding DownloadDisplay}" FontSize="20" FontWeight="Bold" Foreground="#FF4CAF50"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="↑ Upload" FontSize="9" Foreground="Gray"/>
                      <TextBlock Text="{Binding UploadDisplay}" FontSize="20" FontWeight="Bold" Foreground="#FF2196F3"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>

                <!-- Right: IP & Link Speed -->
                <StackPanel Grid.Column="2" Spacing="4" MinWidth="150" VerticalAlignment="Center">
                  <TextBlock Text="{Binding IpAddress, StringFormat='IP: {0}'}" FontSize="12" Foreground="#FFB3B3B3" FontFamily="Consolas,Monospace"/>
                  <TextBlock Text="{Binding SpeedDisplay}" FontSize="11" Foreground="#FF666666"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
