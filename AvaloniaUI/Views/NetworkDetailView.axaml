<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaUI.ViewModels"
             x:Class="AvaloniaUI.Views.NetworkDetailView"
             x:DataType="vm:NetworkDetailViewModel"
             Background="#FF0D0D0D">

  <Design.DataContext>
    <vm:NetworkDetailViewModel />
  </Design.DataContext>

  <ScrollViewer Padding="40,30">
    <StackPanel Spacing="24">
      
      <!-- Header -->
      <StackPanel>
        <TextBlock Text="Network" FontSize="32" FontWeight="Bold" Foreground="White"/>
        <TextBlock Text="Network adapters and traffic" FontSize="13" Foreground="#FF666666" Margin="0,4,0,0"/>
      </StackPanel>

      <!-- Adapter List -->
      <ItemsControl ItemsSource="{Binding NetworkAdapters}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="12"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="#FF141414" CornerRadius="12" Padding="20" BorderBrush="#FF1F1F1F" BorderThickness="1">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                  <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,6,0,0">
                    <TextBlock Text="{Binding Mac}" Foreground="#FF555555" FontSize="11"/>
                    <TextBlock Text="{Binding IpAddress}" Foreground="#FF555555" FontSize="11"/>
                  </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20">
                  <StackPanel>
                    <TextBlock Text="↓ Download" FontSize="9" Foreground="#FF666666"/>
                    <TextBlock Text="{Binding DownloadDisplay}" FontSize="16" FontWeight="Bold" Foreground="#FF4CAF50"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Text="↑ Upload" FontSize="9" Foreground="#FF666666"/>
                    <TextBlock Text="{Binding UploadDisplay}" FontSize="16" FontWeight="Bold" Foreground="#FF2196F3"/>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>
