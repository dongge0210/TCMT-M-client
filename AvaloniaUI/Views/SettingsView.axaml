<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaUI.ViewModels"
             x:Class="AvaloniaUI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="#FF0D0D0D">

  <Design.DataContext>
    <vm:SettingsViewModel AppVersion="v0.14" IPCStatus="Connected"/>
  </Design.DataContext>

  <ScrollViewer Padding="40,30">
    <StackPanel Spacing="24">

      <!-- Header -->
      <StackPanel>
        <TextBlock Text="Settings" FontSize="32" FontWeight="Bold" Foreground="White"/>
        <TextBlock Text="Application configuration and system info" FontSize="13" Foreground="#FF666666" Margin="0,4,0,0"/>
      </StackPanel>

      <!-- About -->
      <Border Background="#FF141414" CornerRadius="12" Padding="20" BorderBrush="#FF1F1F1F" BorderThickness="1">
        <StackPanel Spacing="12">
          <TextBlock Text="ABOUT" Foreground="#FF555555" FontSize="10" FontWeight="Bold"/>
          <Grid ColumnDefinitions="Auto,*">
            <Border Width="40" Height="40" CornerRadius="10" Background="#FF4CAF50" Margin="0,0,12,0">
              <TextBlock Text="T" FontSize="20" FontWeight="Bold" Foreground="White"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="TCMT - 系统硬件监视器" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
              <TextBlock Text="{Binding AppVersion}" FontSize="11" Foreground="#FF666666"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Connection -->
      <Border Background="#FF141414" CornerRadius="12" Padding="20" BorderBrush="#FF1F1F1F" BorderThickness="1">
        <StackPanel Spacing="12">
          <TextBlock Text="CONNECTION" Foreground="#FF555555" FontSize="10" FontWeight="Bold"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="IPC Backend" Foreground="White" FontSize="13"/>
            <TextBlock Text="{Binding IpcStatus}" Foreground="#FF4CAF50" FontSize="12" FontWeight="Medium"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Appearance -->
      <Border Background="#FF141414" CornerRadius="12" Padding="20" BorderBrush="#FF1F1F1F" BorderThickness="1">
        <StackPanel Spacing="12">
          <TextBlock Text="APPEARANCE" Foreground="#FF555555" FontSize="10" FontWeight="Bold"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Theme" Foreground="White" FontSize="13"/>
            <Border Background="#FF1F1F1F" CornerRadius="6" Padding="8,5">
              <TextBlock Text="Dark" Foreground="#FF888888" FontSize="11"/>
            </Border>
          </Grid>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
