<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AvaloniaUI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="1000"
             x:Class="AvaloniaUI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
  
  <Design.DataContext>
    <vm:DashboardViewModel Title="System Overview" CpuUsage="42" MemoryPercent="65" CpuName="AMD Ryzen 9" RamInfo="32GB DDR4"/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">
    <!-- Header Area -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="30,30,30,0">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="System Health Overview" FontSize="13" Foreground="Gray" Margin="0,5,0,0"/>
        </StackPanel>
        <TextBlock Grid.Column="1" Text="TCMT v0.14" FontSize="11" Foreground="#33FFFFFF" VerticalAlignment="Bottom"/>
    </Grid>
    
    <!-- Content Area (Bento Grid) -->
    <ScrollViewer Grid.Row="1" Padding="30,20">
      <StackPanel Spacing="24">
        
        <!-- Row 1: Primary Gauges -->
        <Grid ColumnDefinitions="*,*">
          <!-- CPU Card -->
          <Border Grid.Column="0" Background="#FF1E1E1E" CornerRadius="20" Margin="0,0,12,0" Padding="25" BorderBrush="#FF2A2A2A" BorderThickness="1">
            <StackPanel Spacing="20" HorizontalAlignment="Center">
              <TextBlock Text="PROCESSOR" Foreground="#FF666666" FontSize="11" FontWeight="Bold" LetterSpacing="1" HorizontalAlignment="Center"/>
              <Panel Width="160" Height="160">
                <Arc Width="140" Height="140" Stroke="#FF333333" StrokeThickness="14" StartAngle="140" SweepAngle="260" StrokeJoin="Round" StrokeCap="Round"/>
                <Arc Width="140" Height="140" Stroke="#FF4CAF50" StrokeThickness="14" StartAngle="140" SweepAngle="{Binding CpuUsage, Converter={StaticResource PercentToAngleConverter}}" StrokeJoin="Round" StrokeCap="Round"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F0}%}" FontSize="32" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="LOAD" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
              </Panel>
              <TextBlock Text="{Binding CpuName}" Foreground="#FFB3B3B3" FontSize="14" TextAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Memory Card -->
          <Border Grid.Column="1" Background="#FF1E1E1E" CornerRadius="20" Margin="12,0,0,0" Padding="25" BorderBrush="#FF2A2A2A" BorderThickness="1">
            <StackPanel Spacing="20" HorizontalAlignment="Center">
              <TextBlock Text="MEMORY" Foreground="#FF666666" FontSize="11" FontWeight="Bold" LetterSpacing="1" HorizontalAlignment="Center"/>
              <Panel Width="160" Height="160">
                <Arc Width="140" Height="140" Stroke="#FF333333" StrokeThickness="14" StartAngle="140" SweepAngle="260" StrokeJoin="Round" StrokeCap="Round"/>
                <Arc Width="140" Height="140" Stroke="#FF2196F3" StrokeThickness="14" StartAngle="140" SweepAngle="{Binding MemoryPercent, Converter={StaticResource PercentToAngleConverter}}" StrokeJoin="Round" StrokeCap="Round"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding MemoryPercent, StringFormat={}{0:F0}%}" FontSize="32" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="USED" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
              </Panel>
              <TextBlock Text="{Binding RamInfo}" Foreground="#FFB3B3B3" FontSize="14" TextAlignment="Center"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Row 2: Storage & Network -->
        <Grid ColumnDefinitions="*,320">
          <!-- Storage Bento -->
          <Border Grid.Column="0" Background="#FF1E1E1E" CornerRadius="20" Margin="0,0,12,0" Padding="25" BorderBrush="#FF2A2A2A" BorderThickness="1">
            <StackPanel Spacing="15">
              <TextBlock Text="STORAGE" Foreground="#FF666666" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
              <ItemsControl ItemsSource="{Binding Disks}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,0,0,15" Spacing="8">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding DisplayName}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="{Binding UsageDisplay}" Foreground="#FF4CAF50" FontSize="12" FontWeight="Bold"/>
                      </Grid>
                      <ProgressBar Value="{Binding UsagePercent}" Maximum="100" Height="4" Foreground="#FF4CAF50" Background="#FF333333" CornerRadius="2"/>
                      <TextBlock Text="{Binding TotalSizeDisplay, StringFormat='{0} Total'}" Foreground="#FF666666" FontSize="11"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Network Bento -->
          <Border Grid.Column="1" Background="#FF1E1E1E" CornerRadius="20" Margin="12,0,0,0" Padding="25" BorderBrush="#FF2A2A2A" BorderThickness="1">
            <StackPanel Spacing="20">
              <TextBlock Text="NETWORK" Foreground="#FF666666" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
              <ItemsControl ItemsSource="{Binding NetworkAdapters}">
                  <ItemsControl.ItemTemplate>
                      <DataTemplate>
                          <StackPanel Spacing="15">
                              <StackPanel Spacing="5">
                                  <TextBlock Text="DOWNLOAD" FontSize="10" Foreground="Gray"/>
                                  <TextBlock Text="{Binding DownloadDisplay}" FontSize="24" FontWeight="Bold" Foreground="#FF4CAF50"/>
                              </StackPanel>
                              <StackPanel Spacing="5">
                                  <TextBlock Text="UPLOAD" FontSize="10" Foreground="Gray"/>
                                  <TextBlock Text="{Binding UploadDisplay}" FontSize="24" FontWeight="Bold" Foreground="#FF2196F3"/>
                              </StackPanel>
                              <TextBlock Text="{Binding Name}" Foreground="#FF666666" FontSize="11" TextWrapping="Wrap"/>
                          </StackPanel>
                      </DataTemplate>
                  </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Row 3: Power & Sensors -->
        <Grid ColumnDefinitions="320,*">
             <!-- Power Card -->
             <Border Grid.Column="0" Background="#FF1E1E1E" CornerRadius="20" Margin="0,0,12,0" Padding="25" BorderBrush="#FF2A2A2A" BorderThickness="1">
                <StackPanel Spacing="15">
                    <TextBlock Text="POWER" Foreground="#FF666666" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                    <TextBlock Text="{Binding TotalPowerDisplay}" FontSize="32" FontWeight="Bold" Foreground="#FFFFD700"/>
                    <Grid ColumnDefinitions="*,*,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CPU" FontSize="9" Foreground="Gray"/>
                            <TextBlock Text="{Binding CpuPowerDisplay}" FontSize="12" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="GPU" FontSize="9" Foreground="Gray"/>
                            <TextBlock Text="{Binding GpuPowerDisplay}" FontSize="12" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ANE" FontSize="9" Foreground="Gray"/>
                            <TextBlock Text="{Binding AnePowerDisplay}" FontSize="12" Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
             </Border>

             <!-- Sensors Card -->
             <Border Grid.Column="1" Background="#FF1E1E1E" CornerRadius="20" Margin="12,0,0,0" Padding="25" BorderBrush="#FF2A2A2A" BorderThickness="1">
                <StackPanel Spacing="15">
                    <TextBlock Text="TEMPERATURE SENSORS" Foreground="#FF666666" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                    <ItemsControl ItemsSource="{Binding Temperatures}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FF2A2A2A" CornerRadius="8" Padding="12,8" Margin="0,0,10,10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding SensorName}" Foreground="Gray" FontSize="12"/>
                                        <TextBlock Text="{Binding TemperatureDisplay}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
             </Border>
        </Grid>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
