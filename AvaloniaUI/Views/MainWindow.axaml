<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TCMT.Avalonia.ViewModels"
        xmlns:views="clr-namespace:TCMT.Avalonia.Views"
        x:Class="TCMT.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Height="850" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BackgroundBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.DataTemplates>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="vm:CpuViewModel">
            <views:CpuView />
        </DataTemplate>
        <DataTemplate DataType="vm:MemoryViewModel">
            <views:MemoryView />
        </DataTemplate>
        <DataTemplate DataType="vm:NetworkViewModel">
            <views:NetworkView />
        </DataTemplate>
        <DataTemplate DataType="vm:StorageViewModel">
            <views:StorageView />
        </DataTemplate>
        <DataTemplate DataType="vm:GpuViewModel">
            <views:GpuView />
        </DataTemplate>
        <DataTemplate DataType="vm:TemperaturesViewModel">
            <views:TemperaturesView />
        </DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel">
            <views:SettingsView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="200,*">
        <!-- Sidebar (matching pen design: 200px, dark surface, nav items with text) -->
        <Border Grid.Column="0" 
                Background="{StaticResource SurfaceBrush}" 
                BorderThickness="0,0,1,0" 
                BorderBrush="{StaticResource BorderBrush}">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Logo -->
                <Border Grid.Row="0" 
                        Height="56" 
                        BorderThickness="0,0,0,1" 
                        BorderBrush="{StaticResource BorderBrush}">
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center" 
                                Spacing="10">
                        <Border Width="28" 
                                Height="28" 
                                CornerRadius="8" 
                                Background="{StaticResource SecondaryBrush}">
                            <TextBlock Text="T" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="TCMT" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding NavigationItems}" 
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Background="Transparent" 
                         Margin="8,12,8,0" 
                         BorderThickness="0">

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavigationItem">
                            <Border CornerRadius="8" 
                                    Padding="12,10" 
                                    Margin="0,2"
                                    Background="{Binding IsSelected, Converter={StaticResource NavSelectedToBgConverter}}">
                                <TextBlock Text="{Binding Title}" 
                                           FontSize="13" 
                                           FontWeight="{Binding IsSelected, Converter={StaticResource NavSelectedToFontWeightConverter}}" 
                                           Foreground="{Binding IsSelected, Converter={StaticResource NavSelectedToFgConverter}}"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                </ControlTemplate>
                            </Setter>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="(Panel.Background)" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>

                <!-- Version at bottom -->
                <Border Grid.Row="2" 
                        Height="40" 
                        BorderThickness="0,1,0,0" 
                        BorderBrush="{StaticResource BorderBrush}">
                    <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" 
                               FontSize="11" 
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- TopBar (matching pen design: connection status + refresh) -->
            <Border Grid.Row="0" 
                    Height="36" 
                    Background="{StaticResource SurfaceBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderBrush}"
                    Padding="16,0">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Ellipse Width="7" 
                                 Height="7"
                                 Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                        <TextBlock Text="{Binding ConnectionStatus}" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                Spacing="12"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding AppVersion, StringFormat='TCMT v{0}'}" 
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10"
                                   VerticalAlignment="Center"/>
                        <Button Content="🔄" 
                                Command="{Binding ReconnectCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="2"
                                FontSize="12"
                                ToolTip.Tip="重新连接"
                                Height="24" Width="24"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentControl Grid.Row="1" 
                            Content="{Binding CurrentPage}"
                            Background="{StaticResource BackgroundBrush}"/>
        </Grid>
    </Grid>
</Window>