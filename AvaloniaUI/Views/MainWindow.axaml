<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AvaloniaUI.ViewModels"
        xmlns:views="clr-namespace:AvaloniaUI.Views"
        x:Class="AvaloniaUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Height="800" Width="1200"
        Background="#FF121212">

    <Window.DataTemplates>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="vm:CpuDetailViewModel">
            <views:CpuDetailView />
        </DataTemplate>
        <DataTemplate DataType="vm:StorageDetailViewModel">
            <views:StorageDetailView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="240,*">
        <Border Grid.Column="0" Background="#FF1E1E1E" BorderThickness="0,0,1,0" BorderBrush="#FF333333">
            <StackPanel Margin="0,30,0,0">
                <TextBlock Text="TCMT" Margin="20,0" FontSize="24" FontWeight="Bold" Foreground="#FF4CAF50"/>
                <ListBox ItemsSource="{Binding Pages}" SelectedItem="{Binding CurrentPage}" 
                         Background="Transparent" Margin="10">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ViewModelBase">
                            <Border Padding="15,10" CornerRadius="8">
                                <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
    </Grid>
</Window>
