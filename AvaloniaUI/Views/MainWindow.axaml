<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AvaloniaUI.ViewModels"
        xmlns:views="clr-namespace:AvaloniaUI.Views"
        x:Class="AvaloniaUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Height="800" Width="1200"
        Background="#FF0D0D0D">

    <Window.DataTemplates>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="vm:CpuDetailViewModel">
            <views:CpuDetailView />
        </DataTemplate>
        <DataTemplate DataType="vm:StorageDetailViewModel">
            <views:StorageDetailView />
        </DataTemplate>
        <DataTemplate DataType="vm:NetworkDetailViewModel">
            <views:NetworkDetailView />
        </DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel">
            <views:SettingsView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="200,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#FF141414" BorderThickness="0,0,1,0" BorderBrush="#FF1F1F1F">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="20,24,20,20">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="#FF4CAF50">
                            <TextBlock Text="T" FontSize="16" FontWeight="SemiBold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="TCMT" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Monitor" FontSize="9" Foreground="#FF555555"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Navigation -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Pages}" SelectedItem="{Binding CurrentPage}"
                         Background="Transparent" Margin="10,0" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ViewModelBase">
                            <Border Padding="12,10" CornerRadius="8" Margin="0,3">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding Icon}" FontSize="14"/>
                                    <TextBlock Text="{Binding Title}" Foreground="#FF999999" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      Padding="{TemplateBinding Padding}"/>
                                </ControlTemplate>
                            </Setter>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="(Panel.Background)" Value="#FF1F1F1F"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="(Panel.Background)" Value="#FF1A1A1A"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected TextBlock">
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="16,0,16,16" Spacing="8">
                    <Separator Background="#FF1F1F1F" Height="1"/>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,6,0,0">
                        <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center"
                                 Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" Foreground="#FF555555"
                                   FontSize="9" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        <Button Grid.Column="2" Command="{Binding ReconnectCommand}" IsVisible="{Binding !IsConnected}"
                                Content="重连" FontSize="8" Padding="4,2" CornerRadius="4"
                                Background="#FF1F1F1F" Foreground="#FF666666" BorderThickness="0"/>
                    </Grid>
                    <TextBlock Text="{Binding LastUpdate, StringFormat='{}{0:HH:mm:ss}'}" Foreground="#FF333333" FontSize="8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
    </Grid>
</Window>
