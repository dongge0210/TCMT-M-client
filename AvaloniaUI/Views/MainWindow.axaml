<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AvaloniaUI.ViewModels"
        xmlns:views="clr-namespace:AvaloniaUI.Views"
        x:Class="AvaloniaUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Height="800" Width="1200"
        Background="#FF121212">

    <Window.DataTemplates>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="vm:CpuDetailViewModel">
            <views:CpuDetailView />
        </DataTemplate>
        <DataTemplate DataType="vm:StorageDetailViewModel">
            <views:StorageDetailView />
        </DataTemplate>
        <DataTemplate DataType="vm:NetworkDetailViewModel">
            <views:NetworkDetailView />
        </DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel">
            <views:SettingsView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="240,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#FF1E1E1E" BorderThickness="0,0,1,0" BorderBrush="#FF2A2A2A">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Logo & App Title -->
                <StackPanel Grid.Row="0" Margin="24,28,24,16">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10" Background="#FF4CAF50" Margin="0,0,12,0">
                            <TextBlock Text="T" FontSize="20" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="TCMT" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="System Monitor" FontSize="10" Foreground="#FF666666"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Navigation -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Pages}" SelectedItem="{Binding CurrentPage}"
                         Background="Transparent" Margin="8,0"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ViewModelBase">
                            <Border Padding="14,11" CornerRadius="10" Margin="0,2">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="16"
                                               Foreground="#FF999999" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="White"
                                               FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      Padding="{TemplateBinding Padding}"/>
                                </ControlTemplate>
                            </Setter>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ContentPresenter#PART_ContentPresenter">
                            <Setter Property="(Panel.Background)" Value="#FF2A2A2A"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ContentPresenter#PART_ContentPresenter">
                            <Setter Property="(Panel.Background)" Value="#FF2D2D2D"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected:focus /template/ContentPresenter#PART_ContentPresenter">
                            <Setter Property="(Panel.Background)" Value="#FF2D2D2D"/>
                        </Style>
                        <Style Selector="ListBoxItem:focus-visible /template/ContentPresenter#PART_ContentPresenter">
                            <Setter Property="(Panel.Background)" Value="#FF2D2D2D"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>

                <!-- Footer: Connection Status -->
                <StackPanel Grid.Row="2" Margin="20,0,20,20" Spacing="10">
                    <Separator Background="#FF333333" Height="1"/>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" Foreground="#FF888888"
                                   FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Command="{Binding ReconnectCommand}" IsVisible="{Binding !IsConnected}"
                                Padding="6,2" FontSize="9" CornerRadius="6" Background="#FF333333" Foreground="White"
                                BorderThickness="0" Content="重连" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="{Binding LastUpdate, StringFormat='{}{0:HH:mm:ss}'}" Foreground="#FF555555" FontSize="9"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
    </Grid>
</Window>
