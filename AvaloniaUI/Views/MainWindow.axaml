<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TCMT.Avalonia.ViewModels"
        xmlns:views="clr-namespace:TCMT.Avalonia.Views"
        x:Class="TCMT.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Height="850" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BackgroundBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.DataTemplates>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="vm:CpuViewModel">
            <views:CpuView />
        </DataTemplate>
        <DataTemplate DataType="vm:MemoryViewModel">
            <views:MemoryView />
        </DataTemplate>
        <DataTemplate DataType="vm:NetworkViewModel">
            <views:NetworkView />
        </DataTemplate>
        <DataTemplate DataType="vm:StorageViewModel">
            <views:StorageView />
        </DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel">
            <views:SettingsView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="72,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" 
                Background="{StaticResource SurfaceBrush}" 
                BorderThickness="0,0,1,0" 
                BorderBrush="{StaticResource BorderBrush}">
            <Grid RowDefinitions="Auto,*">
                <!-- Logo -->
                <Border Grid.Row="0" 
                        Height="72" 
                        BorderThickness="0,0,0,1" 
                        BorderBrush="{StaticResource BorderBrush}">
                    <Border Width="36" 
                            Height="36" 
                            CornerRadius="10" 
                            Background="{StaticResource PrimaryBrush}" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                        <TextBlock Text="T" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                </Border>

                <!-- Navigation -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding NavigationItems}" 
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Background="Transparent" 
                         Margin="8,16,8,0" 
                         BorderThickness="0"
                         HorizontalAlignment="Center">

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavigationItem">

                            <Border Width="48" 
                                    Height="48" 
                                    CornerRadius="12" 
                                    Margin="0,4"
                                    Background="Transparent">
                                <TextBlock Text="{Binding Icon}" 
                                           FontSize="22" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                </ControlTemplate>
                            </Setter>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="(Panel.Background)" Value="{StaticResource SurfaceLightBrush}"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="(Panel.Background)" Value="{StaticResource BorderBrush}"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Status Bar -->
            <Border Grid.Row="0" 
                    Height="40" 
                    Background="{StaticResource SurfaceBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderBrush}"
                    Padding="20,0">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Ellipse Width="8" 
                                 Height="8"
                                 Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                        <TextBlock Text="{Binding ConnectionStatus}" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="1" 
                               Text="TCMT v2.0" 
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    
                    <Button Grid.Column="2" 
                            Content="🔄" 
                            Command="{Binding ReconnectCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="4"
                            FontSize="14"
                            ToolTip.Tip="重新连接"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentControl Grid.Row="1" 
                            Content="{Binding CurrentPage}"
                            Background="{StaticResource BackgroundBrush}"/>
        </Grid>
    </Grid>
</Window>