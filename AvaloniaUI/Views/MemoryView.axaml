<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TCMT.Avalonia.ViewModels"
             xmlns:models="clr-namespace:TCMT.Avalonia.Models"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="TCMT.Avalonia.Views.MemoryView"
             x:DataType="vm:MemoryViewModel">

  <Design.DataContext>
    <vm:MemoryViewModel Title="内存" TotalMemory="16 GB" UsedMemory="8.2 GB" MemoryPercent="51" RamType="DDR5" RamSpeed="6400" HasSwap="True" SwapUsedDisplay="514 MB" SwapTotalDisplay="2 GB" CompressedMemory="5.8 GB"/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">
    <!-- TopBar matching pen design -->
    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="14,20">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center">
          <Run Text="内存 · "/><Run Text="{Binding TotalMemory}"/><Run Text=" "/><Run Text="{Binding RamType}"/>
        </TextBlock>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
          <TextBlock Text="{Binding MemoryPercent, StringFormat='{}{0:F0}%'}" FontSize="13" Foreground="{StaticResource SecondaryBrush}"/>
          <TextBlock Text="Updated 2s ago" FontSize="10" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Content matching pen design -->
    <ScrollViewer Grid.Row="1" Background="{StaticResource BackgroundBrush}" Padding="20">
      <StackPanel Spacing="16">

        <!-- UsageBar matching pen design -->
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16">
          <StackPanel Spacing="8">
            <TextBlock Text="内存使用" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <!-- BarTrack -->
            <Border Background="#30363D" CornerRadius="4" Height="24">
              <Grid>
                <Border Background="#3B82F6" CornerRadius="4" HorizontalAlignment="Left" Width="{Binding MemoryPercent, Converter={StaticResource PercentToWidthConverter}}"/>
                <TextBlock Text="{Binding MemoryPercent, StringFormat='{}{0:F0}%'}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Grid>
            </Border>
            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
              <Run Text="{Binding UsedMemory}"/><Run Text=" 已用于 "/><Run Text="{Binding TotalMemory}"/>
            </TextBlock>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding CompressedMemory, StringFormat='压缩: {0}'}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" IsVisible="{Binding HasRamInfo}" Margin="0,0,16,0"/>
              <TextBlock Text="{Binding SwapUsedDisplay, StringFormat='交换: {0}'}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" IsVisible="{Binding HasSwap}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- BreakdownGrid: 4 stat cards matching pen design -->
        <Grid ColumnDefinitions="*,*,*,*" Grid.ColumnSpan="2">
          <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,6,0">
            <StackPanel Spacing="4">
              <TextBlock Text="已用" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock Text="{Binding UsedMemory}" FontSize="18" FontWeight="Bold" Foreground="#3B82F6"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="6,0">
            <StackPanel Spacing="4">
              <TextBlock Text="可用" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock Text="{Binding AvailableMemory}" FontSize="18" FontWeight="Bold" Foreground="#3B82F6"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="6,0">
            <StackPanel Spacing="4">
              <TextBlock Text="压缩" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock Text="{Binding CompressedMemory}" FontSize="18" FontWeight="Bold" Foreground="#3B82F6" IsVisible="{Binding HasRamInfo}"/>
              <TextBlock Text="-" FontSize="18" FontWeight="Bold" Foreground="#3B82F6" IsVisible="{Binding HasRamInfo, Converter={StaticResource BoolInvertConverter}}"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="3" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="6,0,0,0">
            <StackPanel Spacing="4">
              <TextBlock Text="缓存" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock Text="{Binding AvailableMemory}" FontSize="18" FontWeight="Bold" Foreground="#3B82F6"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- DIMM Section matching pen design -->
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16">
          <StackPanel Spacing="8">
            <TextBlock Text="DIMM 温度" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <Rectangle Height="1" Fill="{StaticResource BorderBrush}"/>
            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
              <TextBlock Text="DIMM #1" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock Grid.Column="1" Text="-" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
            </Grid>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="DIMM #2" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock Grid.Column="1" Text="-" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- SpecsRow matching pen design -->
        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24">
          <Run Text="{Binding RamType}"/><Run Text="-"/><Run Text="{Binding RamSpeed, StringFormat='{}{0}'}"/><Run Text=" · 双通道"/>
        </TextBlock>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>