<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaUI.ViewModels"
             x:Class="AvaloniaUI.Views.CpuDetailView"
             x:DataType="vm:CpuDetailViewModel"
             Background="#FF0D0D0D">

  <Design.DataContext>
    <vm:CpuDetailViewModel CpuName="AMD Ryzen 9 7950X" CpuUsage="42.5" CpuTemperature="68.0" CpuFrequency="5700" PhysicalCores="16" LogicalCores="32"/>
  </Design.DataContext>

  <ScrollViewer Padding="40,30">
    <StackPanel Spacing="24">
      
      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock Text="CPU" FontSize="32" FontWeight="Bold" Foreground="White"/>
          <TextBlock Text="{Binding CpuName}" FontSize="13" Foreground="#FF666666" Margin="0,4,0,0"/>
        </StackPanel>
        <Border Background="#FF1A1A1A" CornerRadius="10" Padding="16,12" BorderBrush="#FF252525" BorderThickness="1">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F0}%}" FontSize="22" FontWeight="Bold" Foreground="#FF4CAF50" VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Main Stats Grid -->
      <Grid ColumnDefinitions="*,*,*">
        
        <!-- Usage Card -->
        <Border Grid.Column="0" Background="#FF141414" CornerRadius="16" Padding="24" BorderBrush="#FF1F1F1F" BorderThickness="1" Margin="0,0,16,0">
          <StackPanel Spacing="12">
            <TextBlock Text="USAGE" Foreground="#FF555555" FontSize="10" FontWeight="Bold"/>
            <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F1}%}" FontSize="36" FontWeight="Bold" Foreground="White"/>
            <ProgressBar Value="{Binding CpuUsage}" Maximum="100" Height="4" CornerRadius="2">
              <ProgressBar.Styles>
                <Style Selector="ProgressBar">
                  <Setter Property="Background" Value="#FF1F1F1F"/>
                  <Setter Property="Foreground" Value="#FF4CAF50"/>
                </Style>
              </ProgressBar.Styles>
            </ProgressBar>
          </StackPanel>
        </Border>

        <!-- Temperature Card -->
        <Border Grid.Column="1" Background="#FF141414" CornerRadius="16" Padding="24" BorderBrush="#FF1F1F1F" BorderThickness="1" Margin="8,0">
          <StackPanel Spacing="12">
            <TextBlock Text="TEMPERATURE" Foreground="#FF555555" FontSize="10" FontWeight="Bold"/>
            <TextBlock Text="{Binding CpuTemperature, StringFormat={}{0:F0}°C}" FontSize="36" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Package" FontSize="11" Foreground="#FF666666"/>
          </StackPanel>
        </Border>

        <!-- Frequency Card -->
        <Border Grid.Column="2" Background="#FF141414" CornerRadius="16" Padding="24" BorderBrush="#FF1F1F1F" BorderThickness="1" Margin="16,0,0,0">
          <StackPanel Spacing="12">
            <TextBlock Text="FREQUENCY" Foreground="#FF555555" FontSize="10" FontWeight="Bold"/>
            <TextBlock Text="{Binding CpuFrequency}" FontSize="24" FontWeight="Bold" Foreground="White" FontFamily="Consolas,Monospace"/>
            <TextBlock Text="P-Core" FontSize="11" Foreground="#FF666666"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Core Info -->
      <Border Background="#FF141414" CornerRadius="16" Padding="24" BorderBrush="#FF1F1F1F" BorderThickness="1">
        <StackPanel Spacing="16">
          <TextBlock Text="CORES" Foreground="#FF555555" FontSize="10" FontWeight="Bold"/>
          <Grid ColumnDefinitions="*,*">
            <Border Background="#FF1A1A1A" CornerRadius="12" Padding="20,16" Margin="0,0,8,0">
              <StackPanel Spacing="6">
                <TextBlock Text="Physical Cores" FontSize="11" Foreground="#FF666666"/>
                <TextBlock Text="{Binding PhysicalCores}" FontSize="32" FontWeight="Bold" Foreground="White"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#FF1A1A1A" CornerRadius="12" Padding="20,16" Margin="8,0,0,0">
              <StackPanel Spacing="6">
                <TextBlock Text="Logical Cores" FontSize="11" Foreground="#FF666666"/>
                <TextBlock Text="{Binding LogicalCores}" FontSize="32" FontWeight="Bold" Foreground="White"/>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
